{
	"name": "mapray-navigation",
	"description": "Navigation UI controls for mapray-js viewers.",
	"version": "0.0.4",
	"scripts": {
		"dev": "vite dev",
		"build": "pnpm build:demo && pnpm build:package",
		"build:demo": "vite build",
		"build:package": "svelte-kit sync && svelte-package && publint",
		"publish:npm": "npm publish --registry=https://registry.npmjs.org/",
		"publish:npm:dry-run": "npm publish --dry-run --registry=https://registry.npmjs.org/",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "pnpm build:package",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": false,
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/TakamuneSuda/mapray-navigation.git"
	},
	"bugs": {
		"url": "https://github.com/TakamuneSuda/mapray-navigation/issues"
	},
	"homepage": "https://takamunesuda.github.io/mapray-navigation/",
	"peerDependencies": {
		"@mapray/mapray-js": "0.9.5-fork.2 || ^0.9.6"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@mapray/mapray-js": "^0.9.6",
		"@mapray/ui": "^0.9.6",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^22",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"publint": "^0.3.18",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7"
	},
	"keywords": [
		"mapray",
		"mapray-js",
		"navigation",
		"gis",
		"3d",
		"viewer",
		"globe"
	],
	"author": "Takamune Suda"
}